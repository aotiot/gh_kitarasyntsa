// =============================================================================
// MCP23017 AJURI
// =============================================================================

// Pitää molemmat portit yhtenä pakettina — luetaan yhdellä I2C-transaktiolla
struct McpState {
   uint8_t a;  // GPA0–GPA7: fretit + strum + select
   uint8_t b;  // GPB0–GPB7: start + d-pad + demo
};

// Kirjoita tavu MCP23017:n rekisteriin
void mcpWrite(uint8_t reg, uint8_t val) {
   Wire.beginTransmission(MCP_ADDR);
   Wire.write(reg);
   Wire.write(val);
   Wire.endTransmission();
}

// Lue tavu MCP23017:n rekisteristä
uint8_t mcpRead(uint8_t reg) {
   Wire.beginTransmission(MCP_ADDR);
   Wire.write(reg);
   Wire.endTransmission();
   Wire.requestFrom((uint8_t)MCP_ADDR, (uint8_t)1);
   return Wire.read();
}

// Alusta MCP23017: kaikki pinnit inputiksi, sisäiset pull-upit päälle
void mcpBegin() {
   Wire.begin(MCP_SDA, MCP_SCL);
   mcpWrite(MCP_IODIRA, 0xFF);  // GPA0–7 kaikki input
   mcpWrite(MCP_IODIRB, 0xFF);  // GPB0–7 kaikki input
   mcpWrite(MCP_GPPUA,  0xFF);  // GPA pull-upit päälle
   mcpWrite(MCP_GPPUB,  0xFF);  // GPB pull-upit päälle
}

// Lue molemmat portit yhdellä kertaa — käytä tätä buttonTask:ssa
// tehokkuuden vuoksi: kaksi rekisterilukua yhden I2C-yhteyden avaamisen sijaan
McpState mcpReadAll() {
   McpState s;
   s.a = mcpRead(MCP_GPIOA);
   s.b = mcpRead(MCP_GPIOB);
   return s;
}

// Palauttaa true jos annettu virtuaalipinni on painettuna McpState:ssa.
// Pull-up-logiikka: painettu = LOW = bitti 0 → negoidaan → true.
// Pinnit 0–7 luetaan portista A, pinnit 8–15 portista B.
bool mcpPin(McpState s, uint8_t pin) {
   uint8_t val = (pin < 8) ? s.a : s.b;
   return !((val >> (pin % 8)) & 0x01);
}

